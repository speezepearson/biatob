import { convexTest } from "convex-test";
import { expect, test, describe } from "vitest";
import { api } from "./_generated/api";
import { modules, schema } from "./testHelpers";

// Helper to create a user and get token
async function createUser(
  t: ReturnType<typeof convexTest>,
  user: { username: string; email: string; password: string }
) {
  const { code } = await t.mutation(api.auth.createEmailVerification, {
    email: user.email,
  });
  await t.mutation(api.auth.verifyEmailCode, { email: user.email, code });
  const result = await t.mutation(api.auth.register, {
    username: user.username,
    email: user.email,
    password: user.password,
  });
  return result.token;
}

describe("Relationships", () => {
  describe("setTrusted", () => {
    test("can trust another user", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });
      const bobToken = await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      const result = await t.mutation(api.relationships.setTrusted, {
        token: aliceToken,
        targetUsername: "bob",
        trusted: true,
      });

      expect(result.success).toBe(true);

      // Check relationship
      const bobProfile = await t.query(api.relationships.getUser, {
        username: "bob",
        token: aliceToken,
      });

      expect(bobProfile?.isTrustedByMe).toBe(true);
    });

    test("can untrust a user", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });
      await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      // Trust then untrust
      await t.mutation(api.relationships.setTrusted, {
        token: aliceToken,
        targetUsername: "bob",
        trusted: true,
      });
      await t.mutation(api.relationships.setTrusted, {
        token: aliceToken,
        targetUsername: "bob",
        trusted: false,
      });

      const bobProfile = await t.query(api.relationships.getUser, {
        username: "bob",
        token: aliceToken,
      });

      expect(bobProfile?.isTrustedByMe).toBe(false);
    });

    test("cannot trust yourself", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });

      await expect(
        t.mutation(api.relationships.setTrusted, {
          token: aliceToken,
          targetUsername: "alice",
          trusted: true,
        })
      ).rejects.toThrow("Cannot set trust relationship with yourself");
    });

    test("rejects nonexistent user", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });

      await expect(
        t.mutation(api.relationships.setTrusted, {
          token: aliceToken,
          targetUsername: "nonexistent",
          trusted: true,
        })
      ).rejects.toThrow("User not found");
    });

    test("rejects unauthenticated request", async () => {
      const t = convexTest(schema, modules);
      await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      await expect(
        t.mutation(api.relationships.setTrusted, {
          token: "invalid",
          targetUsername: "bob",
          trusted: true,
        })
      ).rejects.toThrow("Not authenticated");
    });
  });

  describe("getUser", () => {
    test("returns user profile with relationship info", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });
      const bobToken = await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      // Alice trusts Bob
      await t.mutation(api.relationships.setTrusted, {
        token: aliceToken,
        targetUsername: "bob",
        trusted: true,
      });

      const profile = await t.query(api.relationships.getUser, {
        username: "bob",
        token: aliceToken,
      });

      expect(profile).not.toBeNull();
      expect(profile?.username).toBe("bob");
      expect(profile?.isTrustedByMe).toBe(true);
      expect(profile?.trustsMe).toBe(false);
      expect(profile?.mutualTrust).toBe(false);
    });

    test("detects mutual trust", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });
      const bobToken = await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      // Mutual trust
      await t.mutation(api.relationships.setTrusted, {
        token: aliceToken,
        targetUsername: "bob",
        trusted: true,
      });
      await t.mutation(api.relationships.setTrusted, {
        token: bobToken,
        targetUsername: "alice",
        trusted: true,
      });

      const profile = await t.query(api.relationships.getUser, {
        username: "bob",
        token: aliceToken,
      });

      expect(profile?.isTrustedByMe).toBe(true);
      expect(profile?.trustsMe).toBe(true);
      expect(profile?.mutualTrust).toBe(true);
    });

    test("returns null for nonexistent user", async () => {
      const t = convexTest(schema, modules);

      const profile = await t.query(api.relationships.getUser, {
        username: "nonexistent",
      });

      expect(profile).toBeNull();
    });

    test("works without authentication", async () => {
      const t = convexTest(schema, modules);
      await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      const profile = await t.query(api.relationships.getUser, {
        username: "bob",
      });

      expect(profile).not.toBeNull();
      expect(profile?.username).toBe("bob");
      expect(profile?.isTrustedByMe).toBe(false);
      expect(profile?.trustsMe).toBe(false);
    });
  });

  describe("getSettings", () => {
    test("returns user settings with relationships", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });
      const bobToken = await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });
      await createUser(t, {
        username: "charlie",
        email: "charlie@example.com",
        password: "password123",
      });

      // Alice trusts Bob
      await t.mutation(api.relationships.setTrusted, {
        token: aliceToken,
        targetUsername: "bob",
        trusted: true,
      });

      // Bob trusts Alice back
      await t.mutation(api.relationships.setTrusted, {
        token: bobToken,
        targetUsername: "alice",
        trusted: true,
      });

      const settings = await t.query(api.relationships.getSettings, {
        token: aliceToken,
      });

      expect(settings.user.username).toBe("alice");
      expect(settings.trustedUsers.length).toBe(1);
      expect(settings.trustedUsers[0].username).toBe("bob");
      expect(settings.trustedUsers[0].trustsMe).toBe(true);
      expect(settings.trustedByUsers.length).toBe(1);
      expect(settings.trustedByUsers[0].username).toBe("bob");
    });

    test("rejects unauthenticated request", async () => {
      const t = convexTest(schema, modules);

      await expect(
        t.query(api.relationships.getSettings, { token: "invalid" })
      ).rejects.toThrow("Not authenticated");
    });
  });

  describe("sendInvitation", () => {
    test("creates invitation for new email", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });

      const result = await t.mutation(api.relationships.sendInvitation, {
        token: aliceToken,
        recipientEmail: "new@example.com",
      });

      expect(result.success).toBe(true);
      expect(result.alreadyUser).toBe(false);
      expect(result.nonce).toBeDefined();
      expect(result.nonce!.length).toBe(64);
    });

    test("creates trust for existing user", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });
      await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      const result = await t.mutation(api.relationships.sendInvitation, {
        token: aliceToken,
        recipientEmail: "bob@example.com",
      });

      expect(result.success).toBe(true);
      expect(result.alreadyUser).toBe(true);
      expect(result.nonce).toBeNull();

      // Check that Alice now trusts Bob
      const bobProfile = await t.query(api.relationships.getUser, {
        username: "bob",
        token: aliceToken,
      });
      expect(bobProfile?.isTrustedByMe).toBe(true);
    });

    test("normalizes email to lowercase", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });
      await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      const result = await t.mutation(api.relationships.sendInvitation, {
        token: aliceToken,
        recipientEmail: "BOB@EXAMPLE.COM",
      });

      expect(result.alreadyUser).toBe(true);
    });

    test("rejects unauthenticated request", async () => {
      const t = convexTest(schema, modules);

      await expect(
        t.mutation(api.relationships.sendInvitation, {
          token: "invalid",
          recipientEmail: "test@example.com",
        })
      ).rejects.toThrow("Not authenticated");
    });
  });

  describe("checkInvitation", () => {
    test("returns invitation info", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });

      const { nonce } = await t.mutation(api.relationships.sendInvitation, {
        token: aliceToken,
        recipientEmail: "new@example.com",
      });

      const invitation = await t.query(api.relationships.checkInvitation, {
        nonce: nonce!,
      });

      expect(invitation).not.toBeNull();
      expect(invitation?.alreadyAccepted).toBe(false);
      expect(invitation?.inviterUsername).toBe("alice");
      expect(invitation?.recipientEmail).toBe("new@example.com");
    });

    test("returns null for invalid nonce", async () => {
      const t = convexTest(schema, modules);

      const invitation = await t.query(api.relationships.checkInvitation, {
        nonce: "invalid",
      });

      expect(invitation).toBeNull();
    });
  });

  describe("acceptInvitation", () => {
    test("accepts invitation and creates mutual trust", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });

      const { nonce } = await t.mutation(api.relationships.sendInvitation, {
        token: aliceToken,
        recipientEmail: "bob@example.com",
      });

      // Bob signs up and accepts
      const bobToken = await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      const result = await t.mutation(api.relationships.acceptInvitation, {
        nonce: nonce!,
        token: bobToken,
      });

      expect(result.success).toBe(true);
      expect(result.inviterUsername).toBe("alice");

      // Check mutual trust
      const aliceFromBob = await t.query(api.relationships.getUser, {
        username: "alice",
        token: bobToken,
      });
      expect(aliceFromBob?.mutualTrust).toBe(true);

      const bobFromAlice = await t.query(api.relationships.getUser, {
        username: "bob",
        token: aliceToken,
      });
      expect(bobFromAlice?.mutualTrust).toBe(true);
    });

    test("rejects already accepted invitation", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });

      const { nonce } = await t.mutation(api.relationships.sendInvitation, {
        token: aliceToken,
        recipientEmail: "bob@example.com",
      });

      const bobToken = await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      // Accept once
      await t.mutation(api.relationships.acceptInvitation, {
        nonce: nonce!,
        token: bobToken,
      });

      // Try to accept again
      await expect(
        t.mutation(api.relationships.acceptInvitation, {
          nonce: nonce!,
          token: bobToken,
        })
      ).rejects.toThrow("Invitation already accepted");
    });

    test("rejects invalid nonce", async () => {
      const t = convexTest(schema, modules);
      const bobToken = await createUser(t, {
        username: "bob",
        email: "bob@example.com",
        password: "password123",
      });

      await expect(
        t.mutation(api.relationships.acceptInvitation, {
          nonce: "invalid",
          token: bobToken,
        })
      ).rejects.toThrow("Invalid invitation");
    });

    test("rejects unauthenticated request", async () => {
      const t = convexTest(schema, modules);
      const aliceToken = await createUser(t, {
        username: "alice",
        email: "alice@example.com",
        password: "password123",
      });

      const { nonce } = await t.mutation(api.relationships.sendInvitation, {
        token: aliceToken,
        recipientEmail: "bob@example.com",
      });

      await expect(
        t.mutation(api.relationships.acceptInvitation, {
          nonce: nonce!,
          token: "invalid",
        })
      ).rejects.toThrow("Not authenticated");
    });
  });
});
